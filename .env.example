# Copy to `.env` and fill in credentials. `.env` is gitignored.
#
# The default model needs NO keys at all:
#   - prices/volume: yfinance (free)
#   - fundamentals:  SEC EDGAR XBRL companyfacts (free — the SEC requires only
#                    an identifying User-Agent, which config.py sets from
#                    USER_AGENT; there is NO EDGAR API key to obtain)
#   - short interest: FINRA flat files (free)
# The credentials below are consulted ONLY when you opt into an alternative
# source (--source factset/spglobal) or the future WRDS connector.

# WRDS (CRSP / Compustat / IBES via the university subscription).
# These are your WRDS *account* username/password (it is a Postgres login,
# not an API key). Research-only license: WRDS data must never be exported
# to the public dashboard — it is for validation-grade history and papers.
WRDS_USERNAME=
WRDS_PASSWORD=

# S&P Global / Capital IQ point in time fundamentals + estimates
SPGLOBAL_API_KEY=
SPGLOBAL_API_BASE=https://api.marketintelligence.spglobal.com

# FactSet point in time fundamentals + estimate revisions (IBES)
FACTSET_USERNAME=
FACTSET_API_KEY=
FACTSET_API_BASE=https://api.factset.com
