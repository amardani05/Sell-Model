# Copy to `.env` and fill in keys. `.env` is gitignored.
#
# The baseline model needs NO keys — it runs on yfinance + FINRA only.
# These keys are ONLY consulted when you opt into the optional deep history /
# estimate revision factors (config.USE_ESTIMATE_FACTORS / --source factset).

# S&P Global / Capital IQ point in time fundamentals + estimates
SPGLOBAL_API_KEY=
SPGLOBAL_API_BASE=https://api.marketintelligence.spglobal.com

# FactSet point in time fundamentals + estimate revisions (IBES)
FACTSET_USERNAME=
FACTSET_API_KEY=
FACTSET_API_BASE=https://api.factset.com
