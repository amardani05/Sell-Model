## Secrets
.env
.env.local
.env*.local
.vercel

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Cached pipeline data (root-level cache) — but keep the PIT membership store + fallback
/data/*.parquet
/data/price_cache/
/data/*.tmp
!data/sp600_membership.csv
!data/sp600_fallback.csv

