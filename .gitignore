output/

# Webapp build artifacts — NEVER commit these
webapp/node_modules/
webapp/dist/
webapp/.env
webapp/.env.local

# Allow pipeline-generated data into git (these populate the deployed site)
!webapp/public/data/
!webapp/public/meta.json

# IDE / OS
.idea/
.vscode/
.DS_Store
